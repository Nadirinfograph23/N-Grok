{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "installCommand": "npm install && cd n-grok-frontend && npm install",
  "buildCommand": "cd n-grok-frontend && npm run build",
  "outputDirectory": "n-grok-frontend/dist",
  "functions": {
    "api/**/*.py": {
      "maxDuration": 60,
      "runtime": "@vercel/python@4.5.0"
    }
  },
  "rewrites": [
    { "source": "/api/upload-image", "destination": "/api/upload_image" },
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/" }
  ]
}
